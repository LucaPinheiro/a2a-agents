# .gitignore padrão

# Sistema operacional
.DS_Store
Thumbs.db

# Logs e temporários
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
tmp/
temp/
*.swp
*.swo

# Node.js
node_modules/
dist/
build/
.out/
.cache/
.next/
.nuxt/
.parcel-cache/
coverage/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
env/
.env
.env.*

# Ambientes e pacotes Python
*.egg-info/
.eggs/

# IDEs e editores
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Outros
/.env.local
/.env.development.local
/.env.test.local
/.env.production.local